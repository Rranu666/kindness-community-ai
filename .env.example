# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── KindWave App (separate Supabase project) ─────────────────
# 1. Create a new project at https://supabase.com
# 2. Run kindwave-schema.sql in the new project's SQL Editor
# 3. Copy the project URL and anon key from Project Settings → API
VITE_KW_SUPABASE_URL=https://YOUR_KW_PROJECT_ID.supabase.co
VITE_KW_SUPABASE_ANON_KEY=your_kw_supabase_anon_key_here

# ── Optional: Stripe (for payment features) ──────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
