# Remove restrictive headers from image files so social crawlers
# (WhatsApp, Facebook, Telegram) can freely fetch og:image previews.

/og-image.jpg
  ! X-Frame-Options
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/jpeg

/og-image.png
  ! X-Frame-Options
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/png

/*.jpg
  ! X-Frame-Options
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  ! X-Frame-Options
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable

/*.png
  ! X-Frame-Options
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  ! X-Frame-Options
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  ! X-Frame-Options
  ! Content-Security-Policy
  Cache-Control: public, max-age=31536000, immutable
